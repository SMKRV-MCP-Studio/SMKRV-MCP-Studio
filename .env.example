# SMKRV MCP Studio — Environment Variables
# Copy this file to .env and edit as needed

# --- Required ---
# Encryption key for stored credentials (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
STUDIO_ENCRYPTION_KEY=

# JWT secret for admin authentication (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
STUDIO_JWT_SECRET=

# Redis password (internal, used by all services)
REDIS_PASSWORD=studio-redis-secret

# Agent service token (for agent-mcp ↔ backend communication; generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
STUDIO_AGENT_SERVICE_TOKEN=

# --- Optional ---
# Admin credentials (set on first launch, then managed via UI)
# STUDIO_ADMIN_USERNAME=admin
# STUDIO_ADMIN_PASSWORD=

# Prompt injection guard (L0 regex always on; L1 DeBERTa ONNX optional)
# STUDIO_PROMPT_GUARD_ENABLED=true

# --- SSL / Let's Encrypt (optional) ---
# Use Let's Encrypt staging environment for testing (default: false)
# STUDIO_SSL_STAGING=false
# External HTTPS port for HTTP→HTTPS redirects (default: 443)
# STUDIO_EXTERNAL_HTTPS_PORT=443
