@mcp.custom_route("/", methods=["GET", "HEAD", "POST"])
async def root_info(request: Request) -> JSONResponse:
    """Root route — redirect hint to MCP endpoint."""
    is_post = request.method == "POST"
    return JSONResponse(
        {
            **({"error": "MCP endpoint is at /mcp"} if is_post else {"message": "MCP endpoint is at /mcp"}),
            "mcp_endpoint": "/mcp",
            "health": "/health",
        },
        status_code=404 if is_post else 200,
    )


@mcp.custom_route("/health", methods=["GET"])
async def health_check(request: Request) -> JSONResponse:
    """Health endpoint for monitoring."""
    tool_files = list(tools_dir.glob("*.py")) if tools_dir.exists() else []
    resource_files = list(resources_dir.glob("*.py")) if resources_dir.exists() else []
    prompt_files = list(prompts_dir.glob("*.py")) if prompts_dir.exists() else []
    response = {
        "status": "ok",
        "server_name": "{{ config.server_name }}",
        "transport": "{{ config.transport }}",
        "tools_count": len([f for f in tool_files if f.name != "__init__.py"]),
        "resources_count": len([f for f in resource_files if f.name != "__init__.py"]),
        "prompts_count": len([f for f in prompt_files if f.name != "__init__.py"]),
        "mcp_endpoint": "/mcp",
    }
    try:
        from _shared.executor import get_executor
        executor = await get_executor()
        response["queue_metrics"] = await executor.get_all_metrics()
    except Exception:
        response["queue_metrics"] = {}
    return JSONResponse(response)


