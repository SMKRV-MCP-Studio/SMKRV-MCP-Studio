                total_wait = float(data.get("total_wait_ms", 0))
                metrics[conn_id] = {
                    "active_queries": sem_val,
                    "queue_depth": queue_val,
                    "total_queries": total_q,
                    "total_wait_ms": total_wait,
                    "avg_wait_ms": total_wait / total_q if total_q > 0 else 0,
