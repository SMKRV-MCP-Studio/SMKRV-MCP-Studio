                conn_id = key.replace("smkrv:metrics:", "")
                data = await r.hgetall(key)
                sem_val = int(await r.get(f"smkrv:sem:{conn_id}") or 0)
                queue_val = int(await r.get(f"smkrv:queue:{conn_id}") or 0)
