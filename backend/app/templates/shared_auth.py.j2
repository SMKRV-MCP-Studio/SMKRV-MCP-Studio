# ---------------------------------------------------------------------------
# OAuth2 Client Credentials (self-contained)
# ---------------------------------------------------------------------------

_CLIENTS: list[dict[str, str]] = {{ config.oauth_clients_decrypted_repr }}
_TOKEN_TTL: int = {{ config.oauth_token_ttl_seconds or 3600 }}

# In-memory fallback token store
_tokens: dict[str, dict] = {}

_redis = None


async def _get_redis():
    global _redis
    if _redis is not None:
        return _redis
    try:
        import redis.asyncio as aioredis
        _redis = aioredis.from_url(REDIS_URL, decode_responses=True)
        await _redis.ping()
        return _redis
    except Exception:
        _redis = None
        return None


async def _store_token(token: str, client_id: str, ttl: int) -> None:
    """Store token in Redis (preferred) or in-memory."""
    expires_at = time.time() + ttl
    r = await _get_redis()
    if r:
        try:
            key = f"mcp:token:{hashlib.sha256(token.encode()).hexdigest()[:16]}"
            await r.hset(key, mapping={
                "client_id": client_id,
                "expires_at": str(expires_at),
            })
            await r.expire(key, ttl)
            return
        except Exception:
            pass
    _tokens[token] = {"client_id": client_id, "expires_at": expires_at}


async def _validate_token(token: str) -> str | None:
    """Validate token. Returns client_id if valid, None otherwise."""
    now = time.time()
    # Try Redis first
    r = await _get_redis()
    if r:
        try:
            key = f"mcp:token:{hashlib.sha256(token.encode()).hexdigest()[:16]}"
            data = await r.hgetall(key)
            if data and float(data.get("expires_at", 0)) > now:
                return data["client_id"]
            return None
        except Exception:
            pass
    # Fallback: in-memory
    info = _tokens.get(token)
    if info and info["expires_at"] > now:
        return info["client_id"]
    _tokens.pop(token, None)
    return None


async def handle_token_endpoint(request: Request) -> JSONResponse:
    """POST /oauth/token — exchange client_credentials for access token."""
    content_type = request.headers.get("content-type", "")

    try:
        if "application/json" in content_type:
            body = await request.json()
        else:
            form = await request.form()
            body = dict(form)
    except Exception:
        return JSONResponse(
            {"error": "invalid_request", "error_description": "Invalid request body"},
            status_code=400,
        )

    grant_type = body.get("grant_type")
    if grant_type != "client_credentials":
        return JSONResponse(
            {
                "error": "unsupported_grant_type",
                "error_description": "Only client_credentials grant is supported",
            },
            status_code=400,
        )

    client_id = body.get("client_id", "")
    client_secret = body.get("client_secret", "")

    matched = False
    for c in _CLIENTS:
        if (
            hmac.compare_digest(c["client_id"], str(client_id))
            and hmac.compare_digest(c["client_secret"], str(client_secret))
        ):
            matched = True
            break

    if not matched:
        return JSONResponse(
            {"error": "invalid_client", "error_description": "Invalid client credentials"},
            status_code=401,
            headers={"WWW-Authenticate": "Basic"},
        )

    access_token = secrets.token_urlsafe(48)
    await _store_token(access_token, str(client_id), _TOKEN_TTL)

    return JSONResponse({
        "access_token": access_token,
        "token_type": "bearer",
        "expires_in": _TOKEN_TTL,
    })


async def validate_request(request: Request) -> JSONResponse | None:
    """Validate bearer token. Returns error response or None if valid."""
    auth_header = request.headers.get("authorization", "")
    if not auth_header.lower().startswith("bearer "):
        return JSONResponse(
            {"error": "unauthorized", "error_description": "Bearer token required"},
            status_code=401,
            headers={"WWW-Authenticate": "Bearer"},
        )
    token = auth_header[7:]
    client_id = await _validate_token(token)
    if client_id is None:
        return JSONResponse(
            {"error": "invalid_token", "error_description": "Token is invalid or expired"},
            status_code=401,
            headers={"WWW-Authenticate": 'Bearer error="invalid_token"'},
        )
    return None
