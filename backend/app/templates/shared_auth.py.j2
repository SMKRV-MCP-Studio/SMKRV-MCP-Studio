{% if config.auth_type == "bearer" %}
# ---------------------------------------------------------------------------
# Bearer Token Auth (multi-token via Redis)
# ---------------------------------------------------------------------------

_redis = None
# Legacy single-token fallback (from ServerConfig, for backward compat)
_LEGACY_TOKEN = "{{ config.auth_bearer_token_decrypted | escape_quotes }}"


async def _get_redis():
    global _redis
    if _redis is not None:
        return _redis
    try:
        import redis.asyncio as aioredis
        _redis = aioredis.from_url(REDIS_URL, decode_responses=True)
        await _redis.ping()
        return _redis
    except Exception:
        _redis = None
        return None


async def _validate_via_redis(token: str, client_ip: str = "") -> bool:
    """Check token against Redis-stored MCP bearer tokens.

    Tokens are stored by prefix: mcp:bearer:{prefix} -> JSON with bcrypt hash.
    """
    r = await _get_redis()
    if r is None:
        return False
    prefix = token[:12]
    key = f"mcp:bearer:{prefix}"
    try:
        data_raw = await r.get(key)
        if not data_raw:
            return False
        data = json.loads(data_raw)
        token_hash = data.get("token_hash", "")
        if not _bcrypt.checkpw(token.encode(), token_hash.encode()):
            return False
        # Check idle timeout
        usage_key = f"mcp:bearer_usage:{prefix}"
        idle_minutes = data.get("idle_timeout_minutes")
        if idle_minutes:
            last_used_raw = await r.hget(usage_key, "last_used_at")
            if last_used_raw:
                last_used = float(last_used_raw)
                if time.time() - last_used > idle_minutes * 60:
                    return False
        # Update usage tracking (last_used_at + client IP)
        now = time.time()
        usage = {"last_used_at": str(now)}
        if client_ip:
            usage["last_ip"] = client_ip
        await r.hset(usage_key, mapping=usage)
        return True
    except Exception:
        return False


def _get_client_ip(request: Request) -> str:
    """Extract real client IP (CF > X-Forwarded-For > direct)."""
    cf_ip = request.headers.get("cf-connecting-ip")
    if cf_ip:
        return cf_ip.strip()
    forwarded = request.headers.get("x-forwarded-for")
    if forwarded:
        return forwarded.split(",")[0].strip()
    return request.client.host if request.client else ""


async def validate_request(request: Request) -> JSONResponse | None:
    """Validate bearer token. Returns error response or None if valid."""
    auth_header = request.headers.get("authorization", "")
    if not auth_header.lower().startswith("bearer "):
        return JSONResponse(
            {"error": "unauthorized", "error_description": "Bearer token required"},
            status_code=401,
            headers={"WWW-Authenticate": "Bearer"},
        )
    token = auth_header[7:]
    client_ip = _get_client_ip(request)
    # Try multi-token Redis validation first
    if await _validate_via_redis(token, client_ip):
        return None
    # Fallback: legacy single token from ServerConfig
    if _LEGACY_TOKEN and hmac.compare_digest(token, _LEGACY_TOKEN):
        return None
    return JSONResponse(
        {"error": "invalid_token", "error_description": "Invalid token"},
        status_code=401,
        headers={"WWW-Authenticate": 'Bearer error="invalid_token"'},
    )
