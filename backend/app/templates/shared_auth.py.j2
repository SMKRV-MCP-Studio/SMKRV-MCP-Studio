{% if config.auth_type == "oauth_introspection" %}
# ---------------------------------------------------------------------------
# OAuth2 Token Introspection (RFC 7662)
# ---------------------------------------------------------------------------

_INTROSPECT_URL: str = "{{ config.oauth_introspection_url | escape_quotes }}"
_INTROSPECT_CLIENT_ID: str = "{{ config.oauth_introspection_client_id | escape_quotes }}"
_INTROSPECT_CLIENT_SECRET: str = "{{ config.oauth_introspection_client_secret_decrypted | escape_quotes }}"
_CACHE_TTL: int = {{ config.oauth_introspection_cache_seconds or 60 }}

# In-memory cache: token_hash → (active, expires_at)
_introspection_cache: dict[str, tuple[bool, float]] = {}


async def _introspect(token: str) -> bool:
    """Call external introspection endpoint. Returns True if token is active."""
    token_hash = hashlib.sha256(token.encode()).hexdigest()[:16]
    now = time.time()

    # Check cache
    cached = _introspection_cache.get(token_hash)
    if cached and cached[1] > now:
        return cached[0]

    try:
        auth = (
            httpx.BasicAuth(_INTROSPECT_CLIENT_ID, _INTROSPECT_CLIENT_SECRET)
            if _INTROSPECT_CLIENT_ID
            else None
        )
        async with httpx.AsyncClient(timeout=10.0) as client:
            response = await client.post(
                _INTROSPECT_URL,
                data={"token": token},
                auth=auth,
            )
            if response.status_code == 200:
                result = response.json()
                active = bool(result.get("active", False))
                if _CACHE_TTL > 0:
                    _introspection_cache[token_hash] = (active, now + _CACHE_TTL)
                return active
            logger.warning("Introspection endpoint returned %d", response.status_code)
            return False
    except Exception as exc:
        logger.error("Introspection request failed: %s", exc)
        return False


async def validate_request(request: Request) -> JSONResponse | None:
    """Validate bearer token via introspection. Returns error response or None."""
    auth_header = request.headers.get("authorization", "")
    if not auth_header.lower().startswith("bearer "):
        return JSONResponse(
            {"error": "unauthorized", "error_description": "Bearer token required"},
            status_code=401,
            headers={"WWW-Authenticate": "Bearer"},
        )
    token = auth_header[7:]
    active = await _introspect(token)
    if not active:
        return JSONResponse(
            {"error": "invalid_token", "error_description": "Token is inactive or invalid"},
            status_code=401,
            headers={"WWW-Authenticate": 'Bearer error="invalid_token"'},
        )
    return None
{% endif %}


class AuthMiddleware:
    """ASGI middleware that enforces auth on all non-public endpoints."""

    def __init__(self, app):
        self.app = app

    async def __call__(self, scope, receive, send):
        if scope["type"] != "http":
            return await self.app(scope, receive, send)

        request = Request(scope)
        path = request.url.path

        # Public endpoints — no auth
        if path in PUBLIC_PATHS:
            return await self.app(scope, receive, send)

        # All other endpoints require auth
        error_response = await validate_request(request)
        if error_response is not None:
            return await error_response(scope, receive, send)

        return await self.app(scope, receive, send)
