# Auto-generated by SMKRV MCP Studio — {{ now }}
# DO NOT EDIT — this file is regenerated on every deploy.

{# Upstream hosts — configurable for all-in-one (127.0.0.1) vs multi-container (service names) #}
{% set backend_upstream = backend_host | default('backend') ~ ':8000' %}
{% set mcp_upstream = mcp_host | default('mcp') ~ ':8080' %}
{% set agent_mcp_upstream = agent_mcp_host | default('agent-mcp') ~ ':8090' %}
{# HTTP/2: nginx 1.25+ uses "http2 on;" directive; older uses "listen ... http2;" inline #}
{% set h2_modern = http2_modern | default(true) %}

# WebSocket upgrade map
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# Rate limiting zone for API endpoints
limit_req_zone $binary_remote_addr zone=api:10m rate=30r/s;

{% if not ssl_enabled %}
# ======================== HTTP ONLY ========================
server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Disable server version disclosure
    server_tokens off;

    # Request body limit
    client_max_body_size 10m;

    # Security headers (including CSP)
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "0" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob:; connect-src 'self' ws: wss:; worker-src 'self' blob:;" always;

    # Health check endpoint
    location = /health {
        access_log off;
        return 200 'ok';
        add_header Content-Type text/plain;
    }

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy API to backend
    location /api/ {
        proxy_pass http://{{ backend_upstream }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header CF-Connecting-IP $http_cf_connecting_ip;
        proxy_set_header CF-IPCountry $http_cf_ipcountry;

        proxy_connect_timeout 5s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
        proxy_buffer_size 8k;
        proxy_buffers 4 16k;

        limit_req zone=api burst=50 nodelay;
    }

    # Proxy WebSocket for deploy logs
    location /api/v1/deploy/logs {
        proxy_pass http://{{ backend_upstream }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header CF-Connecting-IP $http_cf_connecting_ip;
        proxy_set_header CF-IPCountry $http_cf_ipcountry;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

{% if agent_mcp_enabled %}
    # Proxy Agent MCP server
    location /agent-mcp/ {
        proxy_pass http://{{ agent_mcp_upstream }}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header CF-Connecting-IP $http_cf_connecting_ip;
        proxy_set_header CF-IPCountry $http_cf_ipcountry;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;

        proxy_connect_timeout 5s;
        proxy_buffer_size 8k;
        proxy_buffers 4 16k;
    }
{% endif %}

    # Proxy MCP server (HTTP mode — always proxied through nginx)
    location /mcp {
        proxy_pass http://{{ mcp_upstream }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header CF-Connecting-IP $http_cf_connecting_ip;
        proxy_set_header CF-IPCountry $http_cf_ipcountry;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;

        proxy_connect_timeout 5s;
        proxy_buffer_size 8k;
        proxy_buffers 4 16k;
    }

    # Cache static assets
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    }

    gzip on;
    gzip_min_length 256;
    gzip_types text/plain text/css application/json application/javascript text/xml image/svg+xml application/wasm;
}

{% else %}
# ======================== SSL ENABLED ========================

# --- Port 80: ACME challenge + HTTPS redirect ---
server {
    listen 80 default_server;
    server_name {{ ssl_ui_domain }}{% if ssl_mcp_domain and ssl_mcp_domain != ssl_ui_domain %} {{ ssl_mcp_domain }}{% endif %}{% if agent_mcp_domain and agent_mcp_domain != ssl_ui_domain and agent_mcp_domain != ssl_mcp_domain %} {{ agent_mcp_domain }}{% endif %} _;

    server_tokens off;

    # Health check endpoint (before HTTPS redirect)
    location = /health {
        access_log off;
        return 200 'ok';
        add_header Content-Type text/plain;
    }

    # Let's Encrypt ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Redirect everything else to HTTPS
    location / {
{% if external_https_port and external_https_port != 443 %}
        return 301 https://$host:{{ external_https_port }}$request_uri;
{% else %}
        return 301 https://$host$request_uri;
{% endif %}
    }
}

# --- Port 443: UI Server ({{ ssl_ui_domain }}) ---
