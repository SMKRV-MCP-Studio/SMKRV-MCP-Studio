def mssql_inline_top(sql: str, params: dict) -> tuple[str, dict]:
    """Inline TOP %(param)s as a literal int before pymssql execution.

    pymssql sends all bound parameters as strings, but MSSQL TOP requires
    a literal integer.  This pops the TOP parameter from *params* and
    substitutes it directly into *sql*.
